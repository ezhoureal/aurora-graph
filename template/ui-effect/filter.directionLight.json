{
  "type": "filter.directionLight",
  "label": "Direction Light",
  "category": "Filter",
  "description": "Generates lighting effects from mask and directional light.",
  "accent": "#38bdf8",
  "inputs": [
    {
      "id": "image",
      "label": "Image",
      "kind": "image"
    },
    {
      "id": "mask",
      "label": "Mask",
      "kind": "mask"
    }
  ],
  "outputs": [
    {
      "id": "image",
      "label": "Image",
      "kind": "image"
    }
  ],
  "parameters": [
    {
      "id": "direction",
      "label": "Direction",
      "optional": false,
      "description": "- Direction of light",
      "kind": "point3d",
      "defaultValue": {
        "x": 0,
        "y": 0,
        "z": 0
      },
      "shape": "common2D.Point3d"
    },
    {
      "id": "color",
      "label": "Color",
      "optional": false,
      "description": "- Color of light",
      "kind": "color",
      "defaultValue": {
        "red": 1,
        "green": 1,
        "blue": 1,
        "alpha": 1
      },
      "shape": "Color"
    },
    {
      "id": "intensity",
      "label": "Intensity",
      "optional": false,
      "description": "- Intensity of light",
      "kind": "number",
      "defaultValue": 0,
      "min": 0,
      "max": 100,
      "step": 0.1
    },
    {
      "id": "factor",
      "label": "Factor",
      "optional": true,
      "description": "- Mask scale factor, used to scale the mask channel values",
      "kind": "number",
      "defaultValue": 0,
      "min": 0,
      "max": 100,
      "step": 0.1
    }
  ]
}
